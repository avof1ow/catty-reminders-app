[Unit]
Description=Catty Reminders Application (Lab 2)
After=network.target

[Service]
Type=simple
User=kali
WorkingDirectory=/home/kali/catty-reminders-app
EnvironmentFile=/home/kali/catty-reminders-app/.env
ExecStart=/home/kali/catty-reminders-app/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=3
Environment=PYTHONPATH=/home/kali/catty-reminders-app

[Install]
WantedBy=multi-user.target
